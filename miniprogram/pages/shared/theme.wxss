.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 158rpx;
  background:
    radial-gradient(circle at 8% 10%, rgba(255, 223, 186, 0.55), transparent 25%),
    radial-gradient(circle at 94% 18%, rgba(255, 199, 212, 0.52), transparent 22%),
    linear-gradient(180deg, #fffaf1 0%, var(--page-bg) 58%, #fff6ec 100%);
  overflow: hidden;
}

.theme-female,
.onboarding-page {
  --page-bg: #fff4f6;
  --surface: rgba(255, 255, 252, 0.94);
  --surface-strong: #fffdf8;
  --theme-tint: #fff1f5;
  --theme-soft: #ffdce6;
  --theme-strong: #ff7080;
  --theme-deep: #cf526a;
  --theme-line: #f0a8b5;
  --theme-shadow: rgba(255, 112, 128, 0.25);
  --secondary: #87b3da;
  --approve: #82bd7a;
  --reject: #e9867b;
}

.theme-male {
  --page-bg: #f0f8ff;
  --surface: rgba(255, 255, 252, 0.94);
  --surface-strong: #fffdf8;
  --theme-tint: #eef8ff;
  --theme-soft: #cae7ff;
  --theme-strong: #6eadde;
  --theme-deep: #337db6;
  --theme-line: #7fb8df;
  --theme-shadow: rgba(91, 162, 215, 0.25);
  --secondary: #ff8798;
  --approve: #82bd7a;
  --reject: #e9867b;
}

.poster-title {
  color: #ff6674;
  font-size: 104rpx;
  line-height: 1;
  font-weight: 900;
  text-align: center;
  letter-spacing: 0;
  text-shadow: 0 8rpx 0 rgba(255, 160, 150, 0.12);
}

.poster-subtitle {
  margin-top: 18rpx;
  color: #78564b;
  font-size: 31rpx;
  font-weight: 700;
  text-align: center;
}

.section-title {
  margin-top: 26rpx;
  color: #5a4037;
  font-size: 40rpx;
  font-weight: 900;
  text-align: center;
}

.section-subtitle {
  margin-top: 10rpx;
  color: #9a7b70;
  font-size: 27rpx;
  text-align: center;
}

.primary-button {
  width: calc(100% - 32rpx);
  height: 104rpx;
  margin: 34rpx 16rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff858f 0%, #ff6173 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 104rpx;
  box-shadow: 0 16rpx 34rpx rgba(255, 102, 116, 0.22);
}

.primary-button[disabled] {
  color: rgba(117, 85, 78, 0.26);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

.ghost-button {
  height: 78rpx;
  padding: 0 34rpx;
  border: 3rpx solid var(--theme-line);
  border-radius: 999rpx;
  color: var(--theme-deep);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 78rpx;
  background: rgba(255, 255, 255, 0.76);
}

.soft-panel {
  border: 3rpx solid rgba(229, 193, 174, 0.72);
  border-radius: 34rpx;
  background: var(--surface);
  box-shadow: 0 18rpx 40rpx rgba(125, 87, 74, 0.08);
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #7e6259;
  font-size: 25rpx;
  font-weight: 800;
}

.mini-chip {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--theme-deep);
  background: var(--theme-tint);
  font-size: 23rpx;
  font-weight: 800;
}

.list-surface {
  margin-top: 22rpx;
}

.app-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 128rpx;
  padding: 26rpx;
  border-bottom: 2rpx dashed rgba(214, 178, 159, 0.48);
}

.app-row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #543b34;
  font-size: 30rpx;
  font-weight: 900;
}

.row-meta {
  margin-top: 10rpx;
  color: #a17f73;
  font-size: 24rpx;
}

.row-side {
  min-width: 150rpx;
  text-align: right;
}

.amount {
  color: #543b34;
  font-size: 31rpx;
  font-weight: 900;
}

.status {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: var(--theme-deep);
  background: var(--theme-tint);
  font-size: 22rpx;
  font-weight: 900;
}
