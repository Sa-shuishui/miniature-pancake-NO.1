@import "../shared/theme.wxss";

.profile-card {
  margin-top: 34rpx;
  padding: 36rpx 28rpx;
  text-align: center;
}

.profile-avatar {
  width: 430rpx;
  height: 360rpx;
}

.profile-name {
  margin-top: 12rpx;
  color: var(--theme-deep);
  font-size: 42rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 10rpx;
  color: #8f7066;
  font-size: 26rpx;
  font-weight: 800;
}

.profile-list {
  margin-top: 24rpx;
  padding: 4rpx 26rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 102rpx;
  border-bottom: 2rpx dashed rgba(214, 178, 159, 0.5);
}

.profile-row:last-child {
  border-bottom: 0;
}

.profile-row text:first-child {
  color: #8f7066;
  font-size: 26rpx;
  font-weight: 800;
}

.profile-row text:last-child {
  color: #543b34;
  font-size: 27rpx;
  font-weight: 900;
}

.profile-icon {
  display: block;
  width: 180rpx;
  height: 180rpx;
  margin: 44rpx auto 0;
}
