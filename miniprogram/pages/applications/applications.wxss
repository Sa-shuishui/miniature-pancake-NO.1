@import "../shared/theme.wxss";

.list-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 30rpx;
  padding: 28rpx 24rpx;
}

.list-title {
  color: #543b34;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.22;
}

.list-copy {
  margin-top: 12rpx;
  color: #8f7066;
  font-size: 25rpx;
  line-height: 1.45;
}

.list-hero-img {
  width: 176rpx;
  height: 142rpx;
  flex: 0 0 176rpx;
}

.ledger-panel {
  margin-top: 24rpx;
  padding: 26rpx;
}

.ledger-focus {
  border-color: var(--theme-line);
  box-shadow: 0 18rpx 42rpx var(--theme-shadow);
}

.ledger-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.ledger-title {
  color: #543b34;
  font-size: 34rpx;
  font-weight: 900;
}

.ledger-copy {
  margin-top: 8rpx;
  color: #9a7b70;
  font-size: 24rpx;
}

.ledger-total {
  min-width: 160rpx;
  color: #8f7066;
  text-align: right;
}

.ledger-total text {
  color: var(--theme-deep);
  font-size: 32rpx;
  font-weight: 900;
}

.ledger-total view {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.ledger-form {
  display: grid;
  grid-template-columns: 1.1fr 0.8fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.ledger-field {
  min-width: 0;
}

.ledger-note {
  grid-column: 1 / -1;
}

.label {
  color: #7a5c52;
  font-size: 24rpx;
  font-weight: 900;
}

.ledger-field input {
  box-sizing: border-box;
  width: 100%;
  height: 68rpx;
  margin-top: 10rpx;
  padding: 0 20rpx;
  border: 2rpx solid rgba(229, 193, 174, 0.72);
  border-radius: 22rpx;
  color: #543b34;
  background: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.error {
  margin-top: 8rpx;
  color: #e9867b;
  font-size: 22rpx;
  font-weight: 800;
}

.ledger-button {
  grid-column: 1 / -1;
  height: 76rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: var(--theme-strong);
  font-size: 29rpx;
  font-weight: 900;
  line-height: 76rpx;
  box-shadow: 0 12rpx 24rpx var(--theme-shadow);
}

.ledger-button[disabled] {
  color: rgba(117, 85, 78, 0.28);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: none;
}

.ledger-list {
  margin-top: 20rpx;
}

.ledger-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 2rpx dashed rgba(214, 178, 159, 0.42);
}

.ledger-purpose {
  color: #543b34;
  font-size: 27rpx;
  font-weight: 900;
}

.ledger-meta {
  margin-top: 8rpx;
  color: #a17f73;
  font-size: 22rpx;
  line-height: 1.35;
}

.ledger-amount {
  flex: 0 0 140rpx;
  color: var(--theme-deep);
  font-size: 28rpx;
  font-weight: 900;
  text-align: right;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-top: 26rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter {
  flex: 0 0 auto;
  height: 66rpx;
  padding: 0 26rpx;
  border: 3rpx solid rgba(229, 193, 174, 0.72);
  border-radius: 999rpx;
  color: #8f7066;
  background: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 66rpx;
}

.filter.active {
  border-color: var(--theme-line);
  color: #ffffff;
  background: var(--theme-strong);
  box-shadow: 0 10rpx 22rpx var(--theme-shadow);
}

.empty {
  padding: 54rpx 20rpx;
  color: #9d7d72;
  font-size: 26rpx;
  text-align: center;
}
