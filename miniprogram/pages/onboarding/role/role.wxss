@import "../../shared/theme.wxss";

.role-page {
  padding: 0 26rpx 56rpx;
}

.role-header {
  display: block;
  width: calc(100% + 52rpx);
  height: 420rpx;
  margin: 0 -26rpx;
}

.role-heading {
  margin-top: 30rpx;
}

.role-heading .section-title {
  margin-top: 0;
  color: #3f2e2a;
  font-size: 48rpx;
}

.theme-male .role-heading .section-title {
  color: #256ed0;
}

.theme-female .role-heading .section-title {
  color: #e95878;
}

.role-heading .section-subtitle {
  width: 620rpx;
  max-width: 100%;
  margin: 16rpx auto 0;
  color: #7f6b66;
  font-size: 29rpx;
  line-height: 1.55;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  margin-top: 34rpx;
}

.role-card {
  position: relative;
  height: 384rpx;
  border: 4rpx solid rgba(216, 220, 224, 0.8);
  border-radius: 38rpx;
  overflow: hidden;
  background: #fffdf9;
  box-shadow: 0 18rpx 42rpx rgba(104, 70, 60, 0.09);
}

.role-card.active {
  border-color: var(--theme-line);
  box-shadow: 0 20rpx 44rpx var(--theme-shadow);
}

.role-card-image {
  width: 100%;
  height: 100%;
}

.select-badge {
  position: absolute;
  right: 26rpx;
  top: 26rpx;
  width: 50rpx;
  height: 50rpx;
}

.role-tip {
  margin-top: 30rpx;
  color: #8a7b76;
  font-size: 25rpx;
  text-align: center;
}

.theme-male .primary-button {
  background: linear-gradient(180deg, #61a8ff 0%, #2f85ee 100%);
  box-shadow: 0 16rpx 34rpx rgba(47, 133, 238, 0.22);
}
