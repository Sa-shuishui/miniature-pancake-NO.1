@import "../shared/theme.wxss";

.detail-page {
  padding-bottom: 72rpx;
  overflow: visible;
}

.detail-wrap {
  margin-top: 30rpx;
}

.detail-top {
  padding: 32rpx 28rpx;
  text-align: center;
}

.detail-icon {
  display: block;
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto 14rpx;
}

.status-chip {
  display: inline-flex;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: var(--theme-strong);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.detail-title {
  margin-top: 22rpx;
  color: #543b34;
  font-size: 44rpx;
  font-weight: 900;
}

.detail-amount {
  margin-top: 14rpx;
  color: var(--theme-deep);
  font-size: 54rpx;
  font-weight: 900;
}

.detail-meta {
  margin-top: 12rpx;
  color: #9a7b70;
  font-size: 24rpx;
}

.detail-section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.label {
  color: #60473e;
  font-size: 28rpx;
  font-weight: 900;
}

.body-text,
.link-text {
  margin-top: 14rpx;
  color: #6d5148;
  font-size: 28rpx;
  line-height: 1.65;
}

.link-text {
  color: var(--theme-deep);
  word-break: break-all;
}

textarea {
  width: 100%;
  min-height: 154rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  border: 3rpx solid rgba(229, 193, 174, 0.68);
  border-radius: 24rpx;
  background: #fffaf4;
  color: #4f3932;
  font-size: 28rpx;
  line-height: 1.5;
}

.saved-comment {
  padding-top: 18rpx;
  border-top: 2rpx dashed rgba(214, 178, 159, 0.6);
}

.image-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.thumb {
  width: 188rpx;
  height: 188rpx;
  border-radius: 28rpx;
}

.decision-section {
  margin-top: 26rpx;
  padding: 30rpx 26rpx 34rpx;
  border-color: rgba(240, 168, 181, 0.56);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 250, 252, 0.95) 100%);
  box-shadow: 0 18rpx 42rpx rgba(129, 76, 89, 0.08);
}

.decision-row {
  display: grid;
  grid-template-columns: 252rpx 1fr;
  gap: 36rpx;
  box-sizing: border-box;
  margin-top: 26rpx;
}

.reject-button,
.approve-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 96rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 96rpx;
  letter-spacing: 0;
  overflow: visible;
}

.reject-button {
  border: 3rpx solid #f7c6d1;
  color: #ee98a7;
  background:
    linear-gradient(180deg, #fff9fb 0%, #fff0f5 100%);
  box-shadow:
    0 12rpx 24rpx rgba(238, 152, 167, 0.16),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.92);
}

.approve-button {
  color: #ffffff;
  border: 3rpx solid #2f86ee;
  background:
    radial-gradient(circle at 88% 8%, #fff0a8 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 95% 22%, #fff0a8 0 5rpx, transparent 6rpx),
    linear-gradient(180deg, #83c8ff 0%, #348ff6 55%, #2f83eb 100%);
  box-shadow:
    0 16rpx 28rpx rgba(47, 131, 235, 0.24),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.36);
}

.button-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.reject-button .button-mark {
  color: #ee98a7;
  background: #fff3e7;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.88);
}

.approve-button .button-mark {
  color: #2f83eb;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 6rpx 14rpx rgba(35, 103, 180, 0.18);
}

.theme-male .decision-section {
  border-color: rgba(139, 194, 232, 0.58);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(241, 249, 255, 0.95) 100%);
  box-shadow: 0 18rpx 42rpx rgba(68, 134, 190, 0.1);
}

.theme-male .approve-button {
  background:
    radial-gradient(circle at 88% 8%, #fff0a8 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 95% 22%, #fff0a8 0 5rpx, transparent 6rpx),
    linear-gradient(180deg, #83c8ff 0%, #348ff6 55%, #2f83eb 100%);
  box-shadow:
    0 16rpx 28rpx rgba(47, 131, 235, 0.24),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.36);
}

.theme-female .approve-button .button-mark {
  color: #2f83eb;
}
